BOT_TOKEN=your_telegram_bot_token
# LLM: openai (по умолчанию) или gemini
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# Нужен для эмбеддингов базы знаний (KNOWLEDGE_SYNC) и при LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
# Хранилище: sheets (по умолчанию) или db (Supabase Postgres)
# STORAGE_BACKEND=db
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# DATABASE_SSL_VERIFY=false  # при проблемах SSL на Windows
# SPREADSHEET_ID не нужен при STORAGE_BACKEND=db (таблицу бота можно архивировать)
SPREADSHEET_ID=id_новой_таблицы_бота
SOURCE_SPREADSHEET_ID=id_старой_таблицы_клиента
# Прямой API без зеркал в Sheets
# CALENDAR_ONLY_MODE=true
# TASKS_API_PRIMARY=true
# GOOGLE_TASKS_SHEETS_SYNC_ENABLED=false
# Вкладка с графиком в SOURCE (по умолчанию — как у клиента)
SOURCE_SCHEDULE_SHEET_NAME=График Текущий месяц
# Опционально: JSON {"бармены":"Barista"} — алиасы блоков должностей для парсера графика
# SCHEDULE_ROLE_CATEGORY_ALIASES_JSON=
# Доп. алиасы должностей для поручений (JSON): {"старшийсушеф":["sous_chef"]}
# EMPLOYEE_ROLE_ALIASES_JSON=
# Блок графика для «помощник на смене» / разбор товара (schedule.role): Kleener или JSON ["Kleener"]
# SCHEDULE_UNPACKING_ROLES=Kleener
GOOGLE_CREDENTIALS_JSON=path/to/service_account.json
# Google Sheets: таймаут одного запроса (с), число повторов, параллельных запросов
# GOOGLE_SHEETS_REQUEST_TIMEOUT=20
# GOOGLE_SHEETS_MAX_ATTEMPTS=3
# GOOGLE_SHEETS_MAX_CONCURRENT=2
# Google Tasks (личный Gmail клиента — колонки Ира, Августа…): OAuth, не service account
# GOOGLE_TASKS_USE_OAUTH=true
# GOOGLE_TASKS_OAUTH_CLIENT_JSON=secrets/google_tasks_oauth_client.json
# GOOGLE_TASKS_OAUTH_TOKEN_PATH=secrets/google_tasks_token.json
# Один раз: python scripts/google_tasks_oauth_setup.py
# Привязка списков Tasks ↔ employees: автоматически раз в сутки (см. GOOGLE_TASKS_LISTS_SYNC_*)
# Руководитель (имя или @username из листа employees — НЕ разработчик)
# GOOGLE_TASKS_MANAGER_NAME=valentina_ko
# GOOGLE_TASKS_MANAGER_TELEGRAM_ID=111649379
# GOOGLE_TASKS_MY_LIST_TITLE=Мои задачи
# GOOGLE_TASKS_REMINDERS_ENABLED=true
DRIVE_KNOWLEDGE_FOLDER_ID=id_папки_agent_knowledge_base
# База знаний (RAG): автоиндекс папки Drive и семантический поиск
# KNOWLEDGE_SYNC_ENABLED=true
# KNOWLEDGE_SYNC_HOUR=8
# KNOWLEDGE_SYNC_MINUTE=0
# KNOWLEDGE_CHUNK_MAX_CHARS=900
# KNOWLEDGE_SEARCH_TOP_K=8
# KNOWLEDGE_EMBEDDING_MODEL=text-embedding-004
# Google Calendar (service account должен иметь доступ «Изменение мероприятий» к обоим)
# CALENDAR_ID=email_основного_календаря@gmail.com
# CALENDAR_PRIMARY_ID=...  # опц., иначе = CALENDAR_ID
# CALENDAR_EVENTS_ID=...@group.calendar.google.com  # куда create_event пишет мероприятия
# CALENDAR_PRIMARY_LABEL=Основной
# CALENDAR_EVENTS_LABEL=Мероприятия
# Синк мероприятий Google Calendar → лист events (текущий месяц)
# EVENTS_SYNC_ENABLED=true
# EVENTS_SYNC_HOUR=7
# EVENTS_SYNC_MINUTE=5
WEBHOOK_URL=https://yourdomain.com/webhook
WEBHOOK_SECRET=random_secret_string
TIMEZONE=Europe/Moscow
DEV_MODE=true
# Напоминания по задачам (фаза 4): макс. ЛС на задачу и порог эскалации в общий чат
# TASK_REMINDER_MAX_SENDS=3
# TASK_REMINDER_ESCALATE_AFTER=2
# Часы МСК, когда слать напоминания (пусто = каждые 5 мин как раньше)
TASK_REMINDER_HOURS=10,18
# TASK_REMINDER_WINDOW_MINUTES=3
# Сквозная память (уровень 2): реплики из других чатов в контексте агента
# MEMORY_CROSS_CHAT_ENABLED=true
# MEMORY_CROSS_CHAT_LIMIT=20
# MEMORY_CROSS_CHAT_MAX_CHARS=400
# Лимит объявлений в общий чат (секунды; 0 = без лимита)
# GROUP_NOTICE_COOLDOWN_SEC=3600
# В группе отвечать только при @бота или реплае на бота (true по умолчанию)
# GROUP_AGENT_REQUIRE_MENTION=true
# Импорт открытых задач из Google Tasks в лист tasks каждые 5 мин
# GOOGLE_TASKS_SHEETS_SYNC_ENABLED=true
# Привязка списков Google Tasks → employees.google_tasks_id (раз в сутки)
# GOOGLE_TASKS_LISTS_SYNC_ENABLED=true
# GOOGLE_TASKS_LISTS_SYNC_HOUR=7
# GOOGLE_TASKS_LISTS_SYNC_MINUTE=10
# GOOGLE_TASKS_LISTS_AUTO_REGISTER=true